<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Checklist 485 Post-Higher Education — KMP Consulting</title>
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap" rel="stylesheet"/>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:'Outfit',sans-serif;background:#e8e8e8;padding:28px 16px;color:#1a1a1a;font-size:13px}
.page{background:#fff;width:210mm;max-width:100%;margin:0 auto;box-shadow:0 4px 28px rgba(0,0,0,0.13)}
.hdr{background:linear-gradient(135deg,#F27B20 0%,#F5941E 100%);padding:26px 36px;color:#fff;display:flex;justify-content:space-between;align-items:center}
.logo-wrap{display:flex;align-items:center;gap:12px}
.logo-box{width:44px;height:44px;background:rgba(255,255,255,0.2);border-radius:9px;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:14px;color:#fff;flex-shrink:0;border:2px solid rgba(255,255,255,0.5)}
.logo-name{font-size:19px;font-weight:700}
.logo-name span{font-weight:300}
.logo-sub{font-size:8px;letter-spacing:0.13em;text-transform:uppercase;opacity:0.85;margin-top:2px;display:block}
.hdr-right{text-align:right}
.hdr-visa{font-size:9px;opacity:0.8;text-transform:uppercase;letter-spacing:0.1em;background:rgba(255,255,255,0.15);padding:3px 10px;border-radius:10px;display:inline-block;margin-bottom:6px}
.hdr-type{font-size:13px;font-weight:800;display:block}
.body{padding:22px 36px 26px}
.doc-title{text-align:center;margin-bottom:14px;padding-bottom:12px;border-bottom:1.5px solid #e5e7eb}
.doc-title h1{font-size:15px;font-weight:800;color:#1a1a1a;margin-bottom:3px}
.doc-title p{font-size:10px;color:#6b7280}
.stream-badge{display:inline-block;background:#fff7f0;border:1.5px solid #F27B20;color:#E06A10;font-size:9.5px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;padding:3px 12px;border-radius:20px;margin-bottom:10px}
.intro{border-left:3px solid #F27B20;padding:8px 12px;margin-bottom:16px;font-size:11px;color:#374151;line-height:1.7;background:#fffbf7}
.section{margin-bottom:15px}
.sec-title{font-size:9px;font-weight:700;color:#F27B20;text-transform:uppercase;letter-spacing:0.12em;padding:5px 0;border-bottom:1.5px solid #fde8d0;margin-bottom:0}
.item{display:flex;align-items:flex-start;gap:9px;padding:7px 0;border-bottom:1px solid #f5f5f5}
.item:last-child{border-bottom:none}
.cb{width:14px;height:14px;border:1.5px solid #d1d5db;border-radius:3px;flex-shrink:0;margin-top:1px;cursor:pointer;display:flex;align-items:center;justify-content:center}
.cb.checked{background:#F27B20;border-color:#F27B20}
.cb.checked::after{content:'✓';color:#fff;font-size:9px;font-weight:800}
.item-body{flex:1}
.item-main{font-size:12px;font-weight:700;color:#1a1a1a;line-height:1.4}
.item-note{font-size:10.5px;color:#6b7280;margin-top:2px;line-height:1.5}
.item-warn{font-size:10px;color:#c2410c;margin-top:2px;font-weight:600;line-height:1.5}
.item-info{font-size:10px;color:#1d4ed8;margin-top:2px;font-weight:600;line-height:1.5;background:#eff6ff;padding:4px 8px;border-radius:4px;border-left:2px solid #3b82f6}
.item-link a{font-size:10px;color:#F27B20;margin-top:1px;display:block;text-decoration:none}
.costs-title{font-size:9px;font-weight:700;color:#1a1a1a;text-transform:uppercase;letter-spacing:0.1em;padding:5px 0;border-bottom:1.5px solid #e5e7eb;margin-bottom:10px}
.cost-block{border:1px solid #e5e7eb;border-radius:6px;overflow:hidden;margin-bottom:9px}
.cost-block-hd{background:#f9fafb;padding:7px 12px;font-size:10px;font-weight:700;color:#374151;border-bottom:1px solid #e5e7eb;display:flex;justify-content:space-between;align-items:center}
.method{font-size:9px;font-weight:600;padding:2px 8px;border-radius:8px}
.m-bsb{background:#dcfce7;color:#166534}
.m-card{background:#dbeafe;color:#1e40af}
.m-direct{background:#fef3c7;color:#92400e}
.cost-row{display:flex;justify-content:space-between;padding:5px 12px;border-bottom:1px solid #f5f5f5;font-size:11.5px}
.cost-row:last-child{border-bottom:none;font-weight:800;color:#F27B20}
.cost-note{font-size:10px;color:#6b7280;font-style:italic;padding:5px 12px 7px;background:#f9fafb;border-top:1px solid #f0f0f0}
.sig-box{border:1px solid #e5e7eb;border-radius:6px;padding:13px 16px;margin-bottom:10px}
.sig-hd{font-size:9px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:8px}
.sig-disclaimer{font-size:10.5px;color:#374151;line-height:1.7;margin-bottom:11px}
.sig-grid{display:grid;grid-template-columns:2fr 1fr;gap:16px;margin-bottom:4px}
.sig-input{width:100%;border:none;border-bottom:1.5px solid #9ca3af;padding:6px 0;font-size:13px;font-family:'Outfit',sans-serif;color:#1a1a1a;background:transparent;outline:none}
.sig-input:focus{border-bottom-color:#F27B20}
.sig-input::placeholder{color:#d1d5db}
.sig-lbl{font-size:8.5px;color:#9ca3af;text-transform:uppercase;letter-spacing:0.06em;margin-top:3px}
.submit-wrap{margin-top:14px;display:flex;flex-direction:column;gap:8px}
.submit-btn{width:100%;padding:12px;background:linear-gradient(135deg,#F27B20,#F5941E);border:none;border-radius:8px;color:#fff;font-size:13px;font-weight:700;cursor:pointer;font-family:'Outfit',sans-serif}
.submit-msg{font-size:11px;text-align:center;padding:8px;border-radius:6px;display:none}
.submit-msg.ok{background:#dcfce7;color:#166534;display:block}
.submit-msg.err{background:#fef2f2;color:#991b1b;display:block}
.footer{border-top:1.5px solid #e5e7eb;padding:8px 36px;display:flex;justify-content:space-between;align-items:center}
.footer-l{font-size:9px;color:#9ca3af}
.footer-r{font-size:9px;font-weight:700;color:#F27B20;white-space:nowrap}
.print-btn{position:fixed;bottom:22px;right:22px;background:#F27B20;color:#fff;border:none;padding:11px 18px;border-radius:9px;font-size:13px;font-weight:700;cursor:pointer;font-family:'Outfit',sans-serif;box-shadow:0 4px 14px rgba(242,123,32,0.4)}
@page{size:A4;margin:0}
@media print{
  *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important}
  body{background:#fff!important;padding:0!important}
  .page{box-shadow:none!important;width:100%!important}
  .print-btn{display:none!important}
  .hdr{background:linear-gradient(135deg,#F27B20 0%,#F5941E 100%)!important}
  .intro{background:#fffbf7!important}
  .cost-block-hd,.cost-note{background:#f9fafb!important}
  .m-bsb{background:#dcfce7!important}
  .m-card{background:#dbeafe!important}
  .m-direct{background:#fef3c7!important}
  .item-info{background:#eff6ff!important}
}
</style>
</head>
<body>
<div class="page">
  <div class="hdr">
    <div class="logo-wrap">
      <div class="logo-box">kmp</div>
      <div>
        <div class="logo-name">kmp<span> consulting</span></div>
        <span class="logo-sub">Estratégia que conecta. Futuro que transforma.</span>
      </div>
    </div>
    <div class="hdr-right">
      <span class="hdr-visa">Subclass 485 — Temporary Graduate Visa</span>
      <span class="hdr-type">Single Application — Document Checklist</span>
    </div>
  </div>

  <div class="body">
    <div class="doc-title">
      <div style="text-align:center;margin-bottom:8px"><span class="stream-badge">Post-Higher Education Work Stream</span></div>
      <h1>Document Checklist — Lista de Documentos</h1>
      <p>Reúna todos os documentos e envie para vistos@kmpconsulting.com.au</p>
    </div>
    <div class="intro">Todos os documentos devem ser enviados em formato <strong>PDF ou JPG de alta qualidade</strong>. Documentos incompletos ou ilegíveis podem atrasar o processo.</div>

    <div class="section">
      <div class="sec-title">Documentos Pessoais / Personal Documents</div>
      <div class="item"><div class="cb" onclick="this.classList.toggle('checked')"></div><div class="item-body"><div class="item-main">Passaporte / Passport</div><div class="item-note">Todas as páginas — inclusive as em branco, mesmo sem carimbo</div></div></div>
      <div class="item"><div class="cb" onclick="this.classList.toggle('checked')"></div><div class="item-body"><div class="item-main">Visto Atual / Current Visa</div><div class="item-note">Cópia do visto vigente (VEVO: immi.homeaffairs.gov.au)</div></div></div>
      <div class="item"><div class="cb" onclick="this.classList.toggle('checked')"></div><div class="item-body"><div class="item-main">AFP Police Check — Recibo de Solicitação / Application Receipt</div><div class="item-link"><a href="https://www.afp.gov.au/our-services/national-police-checks" target="_blank">afp.gov.au/our-services/national-police-checks</a></div></div></div>
      <div class="item"><div class="cb" onclick="this.classList.toggle('checked')"></div><div class="item-body"><div class="item-main">AFP Police Check — Resultado / Result</div></div></div>
      <div class="item"><div class="cb" onclick="this.classList.toggle('checked')"></div><div class="item-body"><div class="item-main">Travel History</div><div class="item-note">PDF com todas as páginas do passaporte — incluindo as em branco</div></div></div>
      <div class="item"><div class="cb" onclick="this.classList.toggle('checked')"></div><div class="item-body"><div class="item-main">Comprovante de Endereço / Proof of Address</div><div class="item-note">Conta de luz, gás, internet, extrato bancário ou lease agreement</div></div></div>
      <div class="item"><div class="cb" onclick="this.classList.toggle('checked')"></div><div class="item-body"><div class="item-main">OVHC — Overseas Visitor Health Cover (Single)</div><div class="item-note">Contrate e envie a apólice. Pago mensalmente por você diretamente.</div><div class="item-warn">OSHC não é aceito para o Subclass 485 — obrigatório OVHC</div></div></div>
      <div class="item"><div class="cb" onclick="this.classList.toggle('checked')"></div><div class="item-body">
        <div class="item-main">Resultado IELTS ou PTE (PDF original)</div>
        <div class="item-note"><strong>Score mínimo PTE:</strong> Overall 55 | Listening 40 | Reading 42 | Writing 41 | Speaking 39</div>
        <div class="item-note"><strong>Score mínimo IELTS:</strong> At least 6.5 with a minimum of 5.5 in each component (Listening, Reading, Writing, Speaking)</div>
        <div class="item-warn">Realizado nos últimos 12 meses — data limite do resultado adquirido é o dia anterior ao dia da aplicação</div>
      </div></div>
    </div>

    <div class="section">
      <div class="sec-title">Histórico / History</div>
      <div class="item"><div class="cb" onclick="this.classList.toggle('checked')"></div><div class="item-body"><div class="item-main">Endereços dos Últimos 10 Anos / Address History</div><div class="item-note">Sem gaps entre as datas — mês e ano de entrada e saída de cada endereço</div></div></div>
      <div class="item"><div class="cb" onclick="this.classList.toggle('checked')"></div><div class="item-body"><div class="item-main">Viagens dos Últimos 10 Anos / Travel History</div><div class="item-note">País, motivo e datas (mês e ano) de todas as viagens fora da Austrália</div></div></div>
    </div>

    <div class="section">
      <div class="sec-title">Documentos da Universidade / Education Documents</div>
      <div class="item"><div class="cb" onclick="this.classList.toggle('checked')"></div><div class="item-body">
        <div class="item-main">Completion Letter</div>
        <div class="item-note">Carta de conclusão emitida pela universidade confirmando a finalização do curso</div>
      </div></div>
      <div class="item"><div class="cb" onclick="this.classList.toggle('checked')"></div><div class="item-body">
        <div class="item-main">Academic Transcript (Transcripts Acadêmicos)</div>
        <div class="item-note">Histórico escolar completo com todas as unidades cursadas e resultados obtidos</div>
      </div></div>
      <div class="item"><div class="cb" onclick="this.classList.toggle('checked')"></div><div class="item-body">
        <div class="item-main">Diploma / Degree Certificate</div>
        <div class="item-note">Certificado de conclusão do grau emitido pela universidade</div>
        <div class="item-info">ℹ️ O diploma universitário costuma demorar alguns meses para ser emitido após a conclusão do curso. Não se preocupe — é possível dar entrada na aplicação utilizando apenas os transcripts e a completion letter enquanto o diploma ainda não está disponível.</div>
      </div></div>
      <div class="item"><div class="cb" onclick="this.classList.toggle('checked')"></div><div class="item-body">
        <div class="item-main">CoE(s) — Confirmation of Enrolment</div>
        <div class="item-note">CoE(s) do curso completo — caso o curso tenha sido dividido em mais de um CoE, envie todos</div>
      </div></div>
    </div>

    <div class="section">
      <div class="costs-title">Detalhes de Pagamento / Payment Details</div>
      <div class="cost-block">
        <div class="cost-block-hd"><span>KMP Consulting — Taxa de Serviço / Service Fee</span><span class="method m-bsb">Transferência Bancária</span></div>
        <div class="cost-row"><span>Service Fee</span><span>AUD $1,000.00</span></div>
        <div class="cost-note">BSB: 923100 &nbsp;|&nbsp; Conta: 319505660 &nbsp;|&nbsp; Nome: Keila Mayara Peixoto</div>
      </div>
      <div class="cost-block">
        <div class="cost-block-hd"><span>Governo / Government Application Charge</span><span class="method m-card">Credit Card</span></div>
        <div class="cost-row"><span>Temporary Graduate Visa (VAC)</span><span>AUD $4,600.00</span></div>
        <div class="cost-row"><span>Card Surcharge (1.40%)</span><span>AUD $64.40</span></div>
        <div class="cost-row"><span>Total</span><span>AUD $4,664.40</span></div>
        <div class="cost-note">Pago via cartão de crédito — preencha o Card Authorisation Form da KMP Consulting</div>
      </div>
      <div class="cost-block">
        <div class="cost-block-hd"><span>OVHC — Seguro Saúde / Health Insurance</span><span class="method m-direct">Pago diretamente</span></div>
        <div class="cost-row"><span>Overseas Visitor Health Cover (Single)</span><span>Mensal / Monthly</span></div>
        <div class="cost-note">Contrate (BUPA, NIB, Medibank etc.) e envie a apólice para vistos@kmpconsulting.com.au</div>
      </div>
    </div>

    <div class="sig-box">
      <div class="sig-hd">Client Acknowledgment — Reconhecimento</div>
      <div class="sig-disclaimer">Confirmo que li e compreendi todos os requisitos deste checklist. / <em>I confirm that I have read and understood all requirements listed.</em></div>
      <div class="sig-grid">
        <div><input class="sig-input" id="sig-name" type="text" placeholder="Nome completo / Full name"/><div class="sig-lbl">Nome / Name</div></div>
        <div><input class="sig-input" id="sig-date" type="date"/><div class="sig-lbl">Data / Date</div></div>
      </div>
      <div style="margin-top:12px">
        <input class="sig-input" id="sig-email" type="email" placeholder="Seu e-mail / Your email"/>
        <div class="sig-lbl" style="margin-top:3px">E-mail</div>
      </div>
      <div class="submit-wrap">
        <div class="submit-msg" id="msg"></div>
        <button class="submit-btn" onclick="submitForm()">Enviar / Submit</button>
      </div>
    </div>
    <div style="text-align:center;font-size:9px;color:#9ca3af;margin-bottom:4px">KMP Consulting | vistos@kmpconsulting.com.au</div>
  </div>

  <div class="footer">
    <span class="footer-l">KMP Consulting | vistos@kmpconsulting.com.au</span>
    <span class="footer-r">Subclass 485 — Post-Higher Education Work Stream</span>
  </div>
</div>
<button class="print-btn" onclick="window.print()">Save as PDF</button>

<script>
async function submitForm(){
  const name=document.getElementById('sig-name').value.trim();
  const date=document.getElementById('sig-date').value;
  const email=document.getElementById('sig-email').value.trim();
  const msg=document.getElementById('msg');
  msg.className='submit-msg';msg.style.display='none';
  if(!name||!email){msg.textContent='Por favor, preencha nome e e-mail antes de enviar.';msg.className='submit-msg err';return;}
  try{
    const res=await fetch('https://api.web3forms.com/submit',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({
      access_key:'eb911200-f515-4a77-afbf-61c4f99be8cf',
      subject:`Checklist 485 Post-Higher Education — ${name}`,
      from_name:'Checklist KMP Consulting',
      message:`Checklist Subclass 485 — Post-Higher Education Work Stream\nData: ${new Date().toLocaleString('pt-BR')}\n\nNome: ${name}\nData: ${date}\nE-mail: ${email}`,
      replyto:email
    })});
    const data=await res.json();
    if(data.success){msg.textContent='Checklist enviado com sucesso! Entraremos em contato em breve.';msg.className='submit-msg ok';}
    else throw new Error();
  }catch{msg.textContent='Não foi possível enviar. Tente novamente ou entre em contato diretamente.';msg.className='submit-msg err';}
}
</script>
</body>
</html>
